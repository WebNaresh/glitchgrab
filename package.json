{
  "name": "glitchgrab",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.57.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.0",
    "knip": "^6.0.2",
    "pruny": "^1.42.1",
    "turbo": "^2"
  },
  "packageManager": "bun@1.3.7",
  "private": true,
  "scripts": {
    "dev": "dotenvx run -- turbo dev",
    "dev:web": "dotenvx run -- turbo dev --filter=@glitchgrab/web",
    "dev:mobile": "cd apps/mobile && expo start",
    "build": "dotenvx run -- turbo build --filter=@glitchgrab/web",
    "lint": "turbo lint --",
    "validate": "turbo validate -- && knip && pruny --all --ignore-apps mobile",
    "knip:fix": "knip --fix",
    "pruny:fix": "pruny --fix",
    "db:generate": "cd apps/web && dotenvx run -- ./node_modules/.bin/prisma generate",
    "db:push": "cd apps/web && dotenvx run -- ./node_modules/.bin/prisma db push",
    "db:migrate": "cd apps/web && dotenvx run -- ./node_modules/.bin/prisma migrate dev",
    "db:studio": "cd apps/web && dotenvx run -- ./node_modules/.bin/prisma studio",
    "db:reset": "cd apps/web && dotenvx run -- ./node_modules/.bin/prisma migrate reset --force",
    "razorpay:create-plans": "cd apps/web && dotenvx run -- bun run scripts/create-razorpay-plans.ts",
    "db:sync": "dotenvx run -- bun run scripts/db-sync.ts",
    "install:android:prod": "cd apps/mobile && bun run install:android:prod"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.13.6",
    "next-sitemap": "^4.2.3"
  }
}
