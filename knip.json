{
  "workspaces": {
    "apps/web": {
      "entry": [
        "next.config.{js,ts,cjs,mjs}",
        "app/**/{page,layout,loading,error,not-found,global-error,template,default}.{ts,tsx}",
        "app/**/route.{ts,tsx}",
        "app/**/actions.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "lib/*.ts"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "public/**/*.{png,jpg,jpeg,svg,webp}"
      ],
      "next": {
        "entry": ["next.config.{js,ts,cjs,mjs}"]
      },
      "ignoreDependencies": [
        "tailwindcss",
        "shadcn",
        "tw-animate-css"
      ]
    },
    "apps/mobile": {
      "entry": ["App.tsx", "src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "expo-status-bar",
        "expo-updates",
        "expo-system-ui",
        "eas-cli"
      ]
    },
    "packages/sdk-nextjs": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["react-dom"]
    }
  },
  "ignoreBinaries": ["prisma", "expo"],
  "ignore": ["apps/scripts/**", ".glitchgrab/**"],
  "ignoreExportsUsedInFile": true
}
