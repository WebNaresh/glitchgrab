{
  "workspaces": {
    "apps/web": {
      "entry": [
        "next.config.{js,ts,cjs,mjs}",
        "app/**/{page,layout,loading,error,not-found,global-error,template,default}.{ts,tsx}",
        "app/**/route.{ts,tsx}"
      ],
      "project": [
        "app/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}",
        "public/**/*.{png,jpg,jpeg,svg,webp}"
      ],
      "next": {
        "entry": ["next.config.{js,ts,cjs,mjs}"]
      },
      "ignoreDependencies": ["tailwindcss"]
    }
  },
  "ignoreBinaries": ["tsc"],
  "ignore": ["apps/scripts/**"],
  "ignoreExportsUsedInFile": true
}
